    "version": "0.2.0",
    "configurations": [
        {
            "name": "Demo Site",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "BuildAll",
            "program": "${workspaceFolder}/src/Sample/DemoSite/bin/Debug/net8.0/DemoSite.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/Sample/DemoSite",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/src/Sample/DemoSite/Views"
            }
        },
        {
            "name": "Foundation",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "BuildFoundationAll",
            "program": "${workspaceFolder}/src/Sample/Foundation/bin/Debug/net8.0/Foundation.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/Sample/Foundation",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/src/Sample/Foundation/Views"
            }
        },
        {
            "name": "CMS13",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "buildCMS13",
            "program": "${workspaceFolder}/src/Sample/CMS13/bin/Debug/net10.0/alloy13preview.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/Sample/CMS13",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/src/Sample/CMS13/Views"
            }
        }
    ]
}
